# Configuración del entorno
# Copiar a .env y ajustar valores

# Base de datos
DATABASE_URL=sqlite:///./data/db/catalogacion.db

# OCR
OCR_ENGINE=paddleocr
# OCR_ENGINE=tesseract  # Fallback si PaddleOCR falla

# LLM
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=glm-5.1:cloud
LLM_FALLBACK_MODEL=qwen2.5:7b

# APIs de enriquecimiento
GOOGLE_BOOKS_API_KEY=  # Opcional — funciona sin key pero con rate limit
OPEN_LIBRARY_BASE_URL=https://openlibrary.org/api
CROSSREF_BASE_URL=https://api.crossref.org/works

# App
APP_NAME=Agente IA Catalogación
APP_VERSION=0.1.0
DEBUG=true
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=20